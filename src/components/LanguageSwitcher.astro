---
import { LOCALES, localePath, type LocaleKey } from "../consts";

interface Props {
  locale: LocaleKey;
  copy: any;
}
const { locale, copy } = Astro.props;
---

<label class="lang-label">
  <svg class="lang-icon" aria-hidden="true" viewBox="0 0 24 24" focusable="false">
    <path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z"></path>
    <path d="M3.6 9h16.8M3.6 15h16.8M12 3c2.1 2.3 3.2 5.3 3.2 9s-1.1 6.7-3.2 9M12 3C9.9 5.3 8.8 8.3 8.8 12s1.1 6.7 3.2 9"></path>
  </svg>
  <span class="sr-only">{copy.a11y.language}</span>
  <select class="lang-switcher" aria-label={copy.a11y.language} onchange="if(this.value)window.location.href=this.value">
    {LOCALES.map((l) => (
      <option value={localePath(l.key)} selected={l.key === locale}>{l.label}</option>
    ))}
  </select>
</label>
